# ==========================================
# BACEN Compliance RAG - Variáveis de Ambiente
# ==========================================

# 1. Configurações de Rede (Opcionais)
# Sobrescrevem as portas configuradas no config.yml
# API_HOST=0.0.0.0
# API_PORT=8080
# UI_PORT=8000

# 2. URLs de Conexão
# A URL onde o Frontend Streamlit tentará se comunicar com o Backend FastAPI
# Se omitida, usará a combinação de API_HOST:API_PORT.
# API_URL="http://localhost:8080/api/v1/query"

# 3. Chaves de API de Motores de Inteligência Artificial
# Preencha a chave do serviço que deseja habilitar na UI.
GROQ_API_KEY="sua_chave_groq_aqui"
GEMINI_API_KEY="sua_chave_gemini_aqui"
